# ============================================
# Klin Landing Experience - Environment Setup
# ============================================

# Server Configuration
PORT=5000

# Database (MongoDB)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB=Klin

# Authentication - Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
VITE_RESEND_FROM=noreply@yourdomain.com

# ============================================
# Production Notes
# ============================================
# 1. Update VITE_GOOGLE_REDIRECT_URI to your production domain
#    Example: https://yourdomain.com/auth/callback
#
# 2. Add this URI to Google Cloud Console:
#    Console > OAuth Consent Screen > Authorized Redirect URIs
#
# 3. Change JWT_SECRET to a secure random value
#
# 4. Ensure MONGODB_URI is correct and database is accessible

